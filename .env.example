# ============================================================
# Work Expense Reimbursement Platform — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# --- Supabase (required) ---
# Found at: supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Optional: only needed for Supabase CLI commands ---
# supabase login && supabase link --project-ref <project-id>
# SUPABASE_PROJECT_REF=your-project-ref
